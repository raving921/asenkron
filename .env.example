# ─────────────────────────────────────────
# Kolektif Zihin Yapısı — .env örneği
# Bu dosyayı kopyalayıp .env adıyla kaydet
# ─────────────────────────────────────────

# JWT için rastgele uzun bir string gir
JWT_SECRET=kolektif-zihin-super-secret-buraya-uzun-bir-sey-yaz

# Telegram bot tokenini Railway'den veya BotFather'dan al
TELEGRAM_TOKEN=BURAYA_BOT_TOKENINI_YAZ

# Site URL (Railway deploy sonrası güncelle)
SITE_URL=https://kolektif-zihin.up.railway.app

# Admin anahtarı (değiştirmek istersen)
ADMIN_KEY=1727

# Kullanıcı anahtarı (Almila)
USER_KEY=7979

# Database path (Railway volume için)
DB_PATH=./data/kolektif.db

# Port (Railway otomatik ayarlar)
PORT=3000
